# ============================================================
#  Solana Sniper Bot - Environment Configuration
# ============================================================

# --- Helius RPC + WebSocket ---
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# --- Solana Wallet ---
# Base58-encoded private key van je keypair
WALLET_PRIVATE_KEY=your_base58_private_key_here

# --- Jupiter Aggregator ---
# lite-api is de betrouwbare fallback; quote-api.jup.ag is sneller maar vereist directe internettoegang
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1

# --- Raydium Pool Detection ---
# Program ID van Raydium AMM v4 (niet wijzigen tenzij Raydium upgradet)
RAYDIUM_AMM_PROGRAM_ID=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8

# --- Dry Run (zet op false voor echte transacties) ---
DRY_RUN=true

# --- Swap Instellingen ---
# Hoeveel SOL je per trade wilt inzetten (in SOL, bijv. 0.1)
BUY_AMOUNT_SOL=0.05

# Max slippage in basispunten (bijv. 300 = 3%)
SLIPPAGE_BPS=300

# Prioriteit fee in microLamports (hogere fee = snellere confirmatie)
PRIORITY_FEE_MICRO_LAMPORTS=100000

# --- Take Profit / Stop Loss ---
# Take profit percentage (bijv. 50 = 50% winst)
TAKE_PROFIT_PERCENT=50

# Stop loss percentage (bijv. 20 = 20% verlies)
STOP_LOSS_PERCENT=20

# Hoe vaak (in ms) de TP/SL monitor prijzen checkt
MONITOR_INTERVAL_MS=5000

# --- Filtering Criteria ---
# Minimum liquiditeit in SOL om een pool te accepteren
MIN_LIQUIDITY_SOL=5

# Minimum token supply (om honeypots met 0 supply te filteren)
MIN_TOKEN_SUPPLY=1000000

# Token age: sla pools over die ouder zijn dan X ms na detectie (te laat = te duur)
MAX_TOKEN_AGE_MS=60000

# Max toekomstige openTime: pools die pas over X ms openen worden overgeslagen
MAX_OPEN_TIME_FUTURE_MS=600000

# Deployer history: minimum transacties voor deployer-wallet
MIN_DEPLOYER_TX_COUNT=10

# Honeypot simulatie: simuleer koop én verkoop quote via Jupiter
HONEYPOT_CHECK_ENABLED=true
HONEYPOT_SIM_AMOUNT_SOL=0.001
HONEYPOT_MAX_LOSS_PCT=20
HONEYPOT_SIM_SLIPPAGE_BPS=500

# --- Logging ---
LOG_LEVEL=info
# debug | info | warn | error
